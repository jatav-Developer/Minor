<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>User Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body {
      margin: 0;
      font-family: 'Segoe UI', sans-serif;
      background: #f4f8fb;
    }

    .dashboard-container {
      max-width: 1000px;
      margin: 40px auto;
      padding: 20px;
    }

    h2 {
      text-align: center;
      color: #2c3e50;
      margin-bottom: 30px;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }

    .card {
      background: white;
      padding: 25px;
      border-radius: 12px;
      box-shadow: 0 6px 16px rgba(0,0,0,0.08);
      transition: transform 0.3s ease;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .card h3 {
      margin-top: 0;
      color: #2980b9;
    }

    .card p {
      color: #555;
    }

    .btn {
      display: inline-block;
      margin-top: 15px;
      padding: 10px 18px;
      background-color: #27ae60;
      color: white;
      text-decoration: none;
      border-radius: 8px;
      transition: background-color 0.3s ease;
    }

    .btn:hover {
      background-color: #2ecc71;
    }

    .section {
      background: #fff;
      padding: 25px;
      border-radius: 12px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.06);
      margin-bottom: 30px;
    }

    .section h3 {
      margin-top: 0;
      color: #2c3e50;
    }

    .chart-bar {
      display: flex;
      height: 20px;
      background: #eee;
      border-radius: 10px;
      overflow: hidden;
    }

    .chart-bar span {
      display: block;
      height: 100%;
    }

    .progress {
      width: 70%;
      background-color: #3498db;
    }

    .reminder-box {
      padding: 15px;
      background: #fffae6;
      border-left: 5px solid #f1c40f;
      border-radius: 8px;
      font-weight: 500;
    }

    
/* health goal */
.dashboard-card {
  border: 1px solid #ccc;
  border-radius: 12px;
  padding: 20px;
  margin: 20px 0;
  background: #f9f9f9;
  box-shadow: 0 0 10px rgba(0,0,0,0.05);
}

.dashboard-card h3 {
  margin-bottom: 10px;
  color: #333;
}

.dashboard-card p {
  margin: 5px 0;
}

.dashboard-card .btn {
  display: inline-block;
  margin-top: 10px;
  padding: 8px 16px;
  background-color: #28a745;
  color: white;
  text-decoration: none;
  border-radius: 6px;
}


  </style>
</head>
<body>


    <!-- Navbar -->
  <%- include('partials/navbar.ejs') %>
  <div class="dashboard-container">
    <h2>Welcome back, <%= user.fullName %>!</h2>

    <!-- Top Feature Cards -->
    <div class="cards">
      <div class="dashboard-card">
        <h3>Your Profile</h3>
        <p>Update your personal and health details.</p>
        <a href="/user/profile" class="btn">View Profile</a>
      </div>

      <div class="dashboard-card">
        <h3>Your Cart</h3>
        <p>View selected health products and checkout.</p>
        <a href="/cart" class="btn">View Cart</a>
      </div>

      <div class="dashboard-card">
        <h3>Your Health Goal</h3>
        <% if (user.healthGoal && user.activityLevel) { %>
          <p><strong>Goal:</strong> <%= user.healthGoal %></p>
          <p><strong>Activity:</strong> <%= user.activityLevel %></p>
        <% } else { %>
          <p>You haven’t set your health goal yet.</p>
        <% } %>
        <a href="/user/health-goal" class="btn">Set / Update Goal</a>
        <a href="/user/diet-plan" class="btn">Diet-Plan</a>
      </div>

      <div class="dashboard-card">
        <h3>Health Track</h3>
        <p>Track your current health and achievements here.</p>
        <a href="/user/health-track" class="btn">Track Health</a>
      </div>
      

      <div class="dashboard-card">
        <h3>Recommendations</h3>
        <p>See what products fit your health goals.</p>
        <a href="/products" class="btn">Explore Products</a>
      </div>
    </div>
    
    <!-- Daily Tip Section -->
    <div class="section">
      <h3>💡 Daily Health Tip</h3>
      <p>Stay hydrated — drink at least 8 glasses of water daily to keep your body functioning at its best.</p>
    </div>

    <!-- Progress Chart Section -->
    <div class="section">
      <h3>📈 Weekly Progress</h3>
      <p>70% of your weekly fitness target achieved!</p>
      <div class="chart-bar">
        <span class="progress"></span>
      </div>
    </div>

    <!-- Reminder Section -->
    <div class="section">
      <h3>⏰ Reminders</h3>
      <div class="reminder-box">
        Don't forget to take your vitamin supplement at 9:00 AM today!
      </div>
    </div>
  </div>
 

  </div>

  
  <!-- Footer -->
  <%- include('partials/footer.ejs') %>

</body>
</html>

